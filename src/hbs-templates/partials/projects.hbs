<section class="section section--alt" id="projects">
  <div class="container">
    <div class="section-head reveal">
      <div class="section-eyebrow">// 06 — projects</div>
      <h2 class="section-title"><em>Projects</em></h2>
      <p class="section-sub">A collection of things I've built recently.</p>
    </div>
    {{#if hasManyProjects}}
    <div class="projects__marquee">
      <div class="projects__track">
        {{#each projects}}
          {{> project-card}}
        {{/each}}
        <!-- Duplicate for infinite seamless scroll -->
        {{#each projects}}
          {{> project-card}}
        {{/each}}
      </div>
    </div>
    {{else}}
    <div class="projects__grid">
      {{#each projects}}
        {{> project-card}}
      {{/each}}
    </div>
    {{/if}}
    
    {{^if isProjectsPage}}
    <div style="text-align: center; margin-top: 3rem;">
      <a href="/projects" class="btn btn--outline">View All Projects</a>
    </div>
    {{/if}}
  </div>
</section>
