<div class="timeline-container">
  {{#each certificates}}
  <div class="timeline-item">
    <div class="timeline-header">
      <div>
        <div class="timeline-title" style="font-size: 1rem;">{{this.name}}</div>
        <div class="timeline-subtitle" style="font-size: 0.85rem;">{{this.issuer}}</div>
      </div>
    </div>
    {{#if this.description}}
      <p style="font-size: 0.85rem; color: var(--color-text-main); margin-top: 0.5rem; margin-bottom: 0.5rem;">{{this.description}}</p>
    {{/if}}
    {{#if this.tags}}
    <div class="pill-container" style="margin-top: 0.25rem; margin-bottom: 0.5rem;">
      {{#each this.tags}}
      <span class="pill" style="font-size: 0.65rem; padding: 0.15rem 0.3rem; background: var(--color-bg-page); color: var(--color-text-muted); border: 1px solid var(--color-border);">{{this}}</span>
      {{/each}}
    </div>
    {{/if}}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid var(--color-bg-page);">
      <span class="timeline-date">{{this.issued}}</span>
      {{#if this.credentialUrl}}
        <a href="{{this.credentialUrl}}" target="_blank" rel="noopener noreferrer" style="font-size: 0.85rem; font-weight: 600; display: inline-flex; align-items: center; gap: 4px;">
          View <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
      {{/if}}
    </div>
  </div>
  {{/each}}
</div>