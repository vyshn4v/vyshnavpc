<section class="section" id="certificates">
  <div class="container">

    <div class="section-head reveal">
      <div class="section-eyebrow">// 03 — certificates</div>
      <h2 class="section-title">Certifi<em>cations</em></h2>
      <p class="section-sub">Industry-recognised credentials validating
        expertise across cloud, DevOps, and software engineering.</p>
    </div>

    <div class="cert-grid">
      {{#each certificates}}
        <div class="cert-card reveal" style="--clr: {{this.color}}">
          <div class="cert-glow"></div>
          <div class="cert-header">
            <div class="cert-issuer-badge">{{this.issuerAbbr}}</div>
            <div class="cert-meta">
              <span class="cert-issued">Issued {{this.issued}}</span>
              {{#if this.expires}}
                <span class="cert-expires">Expires {{this.expires}}</span>
              {{else}}
                <span class="cert-expires cert-no-exp">No Expiry</span>
              {{/if}}
            </div>
          </div>
          <div class="cert-body">
            <h3 class="cert-title">{{this.name}}</h3>
            <p class="cert-issuer">{{this.issuer}}</p>
            <p class="cert-desc">{{this.description}}</p>
          </div>
          <div class="cert-footer">
            <div class="cert-tags">
              {{#each this.tags}}
                <span class="ptag">{{this}}</span>
              {{/each}}
            </div>
            {{#if this.credentialUrl}}
              <a
                href="{{this.credentialUrl}}"
                target="_blank"
                class="cert-link"
              >
                View credential →
              </a>
            {{/if}}
          </div>
        </div>
      {{/each}}
    </div>

  </div>
</section>