<section class="section section--alt" id="experience">
  <div class="container">

    <div class="section-head reveal">
      <div class="section-eyebrow">// 02 — experience</div>
      <h2 class="section-title">Work <em>Experience</em></h2>
      <p class="section-sub">Building backend systems, REST APIs, and DevOps
        infrastructure in production environments.</p>
    </div>

    {{#each experience}}
      <div class="exp-block reveal">
        <div class="exp-meta">
          <span class="exp-period">{{this.period}}</span>
          <span class="exp-company">{{this.company}}</span>
        </div>
        <div class="exp-card">
          <h3 class="exp-role">{{this.role}}</h3>
          <ul class="exp-list">
            {{#each this.highlights}}
              <li>{{this}}</li>
            {{/each}}
          </ul>
        </div>
      </div>
    {{/each}}

  </div>
</section>