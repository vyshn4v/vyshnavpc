{{! ══════════════════════════════════════════════════════════
section-know-more.hbs
"Want to know more?" teaser section — drop inside index.hbs
Links to /journey
══════════════════════════════════════════════════════════ }}

<section class="knowmore section" id="know-more">
  <div class="container">

    <div class="knowmore__inner">

      <!-- Left: decorative terminal block -->
      <div class="knowmore__terminal" aria-hidden="true">
        <div class="knowmore__term-bar">
          <span class="tb tb--red"></span>
          <span class="tb tb--yellow"></span>
          <span class="tb tb--green"></span>
          <span class="knowmore__term-title">journey.log</span>
        </div>
        <div class="knowmore__term-body">
          <p class="knowmore__log-line">
            <span class="tk-op">$</span>
            <span class="tk-fn"> cat</span>
            <span class="tk-str"> journey.log</span>
          </p>
          {{#each know_more.logs}}
            <p class="knowmore__log-line knowmore__log-line--dim">──
              {{this}}
            </p>
          {{/each}}
          {{! <p class="knowmore__log-line knowmore__log-line--dim">── 2022 enrolled
            MERN bootcamp</p>
          <p class="knowmore__log-line knowmore__log-line--dim">── 2023 landed
            first dev role</p>
          <p class="knowmore__log-line knowmore__log-line--dim">── 2024 promoted
            → SDE 1 @ Neutrinos</p>
          <p class="knowmore__log-line knowmore__log-line--dim">── 2025
            Kubernetes in prod ✓</p>
          <p class="knowmore__log-line knowmore__log-line--dim">── 2026
            open_to_work=true</p> }}
          <p class="knowmore__log-line knowmore__log-cursor">
            <span class="tk-op">$</span>
            <span class="cursor">▋</span>
          </p>
        </div>
      </div>

      <!-- Right: CTA copy -->
      <div class="knowmore__copy">
        <p class="knowmore__eyebrow">
          <span class="knowmore__eyebrow-line"></span>
          {{know_more.eyebrow}}
          <span class="knowmore__eyebrow-line"></span>
        </p>

        <h2 class="knowmore__heading">
          Want to know<br />
          <em>more about me?</em>
        </h2>

        <p class="knowmore__sub">
          I didn't start as a backend engineer. I started with curiosity, a
          laptop, and way too many browser tabs. Follow the honest, unfiltered
          story of how I went from blinking cursors to production Kubernetes
          clusters.
        </p>

        <ul class="knowmore__pills" aria-label="Journey highlights">
          {{#each know_more.pills}}
            <li class="knowmore__pill">
              <span class="knowmore__pill-dot"></span>
              {{this}}
            </li>
          {{/each}}
          {{! <li class="knowmore__pill">
            <span class="knowmore__pill-dot"></span>
            First production outage
          </li>
          <li class="knowmore__pill">
            <span class="knowmore__pill-dot"></span>
            DevOps rabbit hole
          </li>
          <li class="knowmore__pill">
            <span class="knowmore__pill-dot"></span>
            What's next
          </li> }}
        </ul>

        <a href="{{{know_more.href.url}}}" class="knowmore__cta">
          <span>{{know_more.href.button_text}}</span>
          <svg
            class="knowmore__cta-arrow"
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>