
<!-- Premium Contact Modal -->
<div class="premium-modal-backdrop" id="modalBackdrop">
  <div class="premium-modal">
    <div class="modal-head">
      <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--color-text-title);">Let's work together</h3>
      <p style="font-size: 0.875rem; color: var(--color-text-muted);">Fill in the details and I'll get back to you within 24 hours.</p>
      <button class="modal-close" id="closeContact" aria-label="Close contact form">×</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>First name</label>
          <input type="text" id="fname" placeholder="John" />
          <div class="field-error" id="err-fname"></div>
        </div>
        <div class="form-group">
          <label>Last name</label>
          <input type="text" id="lname" placeholder="Doe" />
          <div class="field-error" id="err-lname"></div>
        </div>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" id="femail" placeholder="john@example.com" />
        <div class="field-error" id="err-femail"></div>
      </div>
      <div class="form-group">
        <label>Subject</label>
        <input type="text" id="fsubject" placeholder="Project inquiry" />
        <div class="field-error" id="err-fsubject"></div>
      </div>
      <div class="form-group">
        <label>Message</label>
        <textarea id="fmessage" rows="4" placeholder="Tell me about your project..."></textarea>
        <div class="field-error" id="err-fmessage"></div>
      </div>
      {{#if turnstileSiteKey}}
      <div class="cf-turnstile" data-sitekey="{{turnstileSiteKey}}" data-theme="light"></div>
      {{/if}}
      <div class="modal-actions">
        <button class="btn-premium outline" id="cancelContact" style="flex: 1; justify-content: center;">Cancel</button>
        <button class="btn-premium" id="sendContact" style="flex: 1; justify-content: center;">Send Message</button>
      </div>
    </div>
  </div>
</div>
