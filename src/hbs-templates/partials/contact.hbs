<div class="contact-list">
  {{#if site.email}}
  <a href="mailto:{{site.email}}">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="meta-icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
    {{site.email}}
  </a>
  {{/if}}

  {{#if site.github}}
  <a href="{{site.github}}" target="_blank" rel="noopener noreferrer">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="meta-icon"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
    GitHub Profile
  </a>
  {{/if}}
  
  {{#if site.linkedin}}
  <a href="{{site.linkedin}}" target="_blank" rel="noopener noreferrer">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="meta-icon"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
    LinkedIn Profile
  </a>
  {{/if}}

  <button class="btn-premium" id="openContact" style="width: 100%; justify-content: center; margin-top: 1rem;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
    Send a Message
  </button>
</div>

<!-- Premium Contact Modal -->
<div class="premium-modal-backdrop" id="modalBackdrop">
  <div class="premium-modal">
    <div class="modal-head">
      <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--color-text-title);">Let's work together</h3>
      <p style="font-size: 0.875rem; color: var(--color-text-muted);">Fill in the details and I'll get back to you within 24 hours.</p>
      <button class="modal-close" id="closeContact">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <div class="form-group">
          <label>First name</label>
          <input type="text" id="fname" placeholder="John" />
          <div class="field-error" id="err-fname"></div>
        </div>
        <div class="form-group">
          <label>Last name</label>
          <input type="text" id="lname" placeholder="Doe" />
          <div class="field-error" id="err-lname"></div>
        </div>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" id="femail" placeholder="john@example.com" />
        <div class="field-error" id="err-femail"></div>
      </div>
      <div class="form-group">
        <label>Subject</label>
        <input type="text" id="fsubject" placeholder="Project inquiry" />
        <div class="field-error" id="err-fsubject"></div>
      </div>
      <div class="form-group">
        <label>Message</label>
        <textarea id="fmessage" rows="4" placeholder="Tell me about your project..."></textarea>
        <div class="field-error" id="err-fmessage"></div>
      </div>
      <div class="cf-turnstile" data-sitekey="{{turnstileSiteKey}}" data-theme="light"></div>
      <div class="modal-actions">
        <button class="btn-premium outline" id="cancelContact" style="flex: 1; justify-content: center;">Cancel</button>
        <button class="btn-premium" id="sendContact" style="flex: 1; justify-content: center;">Send Message</button>
      </div>
    </div>
  </div>
</div>