<article class="project-card project-card--clickable" 
  data-title="{{this.title}}" 
  data-desc="{{this.description}}" 
  data-image="{{this.image}}" 
  data-github="{{#if this.github}}{{this.github}}{{else}}{{#if (isGithubUrl this.link)}}{{this.link}}{{/if}}{{/if}}" 
  data-live="{{#if this.live}}{{this.live}}{{else}}{{#if this.live_link}}{{this.live_link}}{{else}}{{^if (isGithubUrl this.link)}}{{this.link}}{{/if}}{{/if}}{{/if}}"
  data-tech="{{#if this.technologies}}{{#each this.technologies}}{{this}}{{#unless @last}},{{/unless}}{{/each}}{{/if}}">
  {{#if this.image}}
  <div class="project-card__image-wrapper">
    <img src="{{this.image}}" alt="Screenshot of {{this.title}} project by Vyshnav" class="project-card__image" loading="lazy">
  </div>
  {{/if}}
  <div class="project-card__content">
    <div class="project-card__header">
      <h3 class="project-card__title">{{this.title}}</h3>
      <div class="project-card__links">
        {{#if this.github}}
        <a href="{{this.github}}" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="GitHub Repository">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        </a>
        {{/if}}
        {{#if this.live}}
        <a href="{{this.live}}" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="Live Demo">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
        {{else if this.live_link}}
        <a href="{{this.live_link}}" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="Live Demo">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
        {{/if}}
        {{#if this.link}}
          {{#if (isGithubUrl this.link)}}
          <a href="{{this.link}}" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="GitHub Repository">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          </a>
          {{else}}
          <a href="{{this.link}}" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="Project Link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
          </a>
          {{/if}}
        {{/if}}
      </div>
    </div>
    
    <p class="project-card__desc">{{this.description}}</p>
    
    {{#if this.technologies}}
    <ul class="project-card__tech">
      {{#each this.technologies}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
    {{/if}}
  </div>
</article>
