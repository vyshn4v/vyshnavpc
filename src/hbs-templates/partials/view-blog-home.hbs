<div class="blog-filter-panel">
  <div class="blog-filter-bar" id="filterBar">
    <button class="filter-btn active" data-filter="all">All posts</button>
    {{#each categories}}
      <button class="filter-btn" data-filter="{{slug}}">
        {{icon}} {{label}}
      </button>
    {{/each}}
  </div>
</div>

{{#if featured}}
  <section class="featured-post-card">
    <h2 class="section-heading">Featured Post</h2>
    <div class="featured-post-wrap">
      {{> blog-card featured}}
    </div>
  </section>
{{/if}}

<section class="all-posts-card">
  <h2 class="section-heading">All Posts</h2>
  <div class="projects-grid" id="postsGrid">
    {{#each posts}}
      {{> blog-card this}}
    {{/each}}
  </div>

  {{#unless posts}}
    <div class="empty-state">
      <p>No posts yet. Check back soon.</p>
    </div>
  {{/unless}}
</section>
