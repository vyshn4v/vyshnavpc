<div class="timeline-container">
  {{#each education}}
  <div class="timeline-item">
    <div class="timeline-header">
      <div>
        <div class="timeline-title">{{this.title}}</div>
        <div class="timeline-subtitle">{{this.institution}}</div>
      </div>
      <div class="timeline-date">{{this.period}}</div>
    </div>
    {{#if this.subtitle}}
      <p class="timeline-desc">{{this.subtitle}}</p>
    {{/if}}
  </div>
  {{/each}}
</div>