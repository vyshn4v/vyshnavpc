  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T4R9GT7H"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    
    {{> nav}}

    <main>
      {{{body}}}
    </main>
    {{> footer}}

    <!-- Global Contact Modal -->
    <button class="floating-contact-btn" id="openContact" aria-label="Contact Developer">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
    </button>

    {{> contact}}

    {{{_sections.scripts}}}
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        // Handle trigger-contact-modal class for nav links
        const triggers = document.querySelectorAll(".trigger-contact-modal");
        const modalBackdrop = document.getElementById("modalBackdrop");
        
        if (modalBackdrop) {
          const openModal = (e) => {
            if (e) e.preventDefault();
            modalBackdrop.classList.add("is-open");
          };
          
          triggers.forEach(trigger => {
            trigger.addEventListener("click", openModal);
          });
        }
      });
    </script>

    <script src="/js/main.js?v=6"></script>
    <!-- Cookie Consent Banner -->
    <div id="cookieConsentBanner" class="cookie-consent-banner">
      <div class="cookie-consent-content">
        <p class="cookie-consent-text">
          This website uses Google Analytics and Microsoft Clarity to understand how visitors interact with the site and improve the experience. 
          By continuing to use the site, you agree to these data collection policies. 
          <a href="https://www.microsoft.com/privacy/privacystatement" target="_blank" rel="noopener noreferrer">Learn more</a>.
        </p>
        <div class="cookie-consent-actions">
          <button id="acceptCookies" class="btn btn-primary cookie-btn">Got it</button>
        </div>
      </div>
    </div>

    <script>
      // Lazy-load all scripts on interaction (Informational consent mode)
      (function() {
        let essentialLoaded = false;
        
        function loadEssentialScripts() {
          if (essentialLoaded) return;
          essentialLoaded = true;
          
          // Turnstile
          const ts = document.createElement('script');
          ts.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
          ts.async = true;
          ts.defer = true;
          document.head.appendChild(ts);
        }
        
        ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'].forEach(function(e) {
          window.addEventListener(e, loadEssentialScripts, { once: true, passive: true });
        });

        // Tracking Scripts Logic
        let trackingLoaded = false;
        
        function loadTrackingScripts() {
          if (trackingLoaded) return;
          trackingLoaded = true;
          
          // GA4
          const ga = document.createElement('script');
          ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-T3JV9SSWP5';
          ga.async = true;
          document.head.appendChild(ga);
          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-T3JV9SSWP5');
          
          // GTM
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','GTM-T4R9GT7H');

          {{#if clarityId}}
          // Microsoft Clarity
          (function(c,l,a,r,i,t,y){
              c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
              t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
              y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", "{{clarityId}}");
          {{/if}}
        }

        // Always load tracking scripts on interaction, since consent is informational only
        ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'].forEach(function(e) {
          window.addEventListener(e, loadTrackingScripts, { once: true, passive: true });
        });

        const consentBanner = document.getElementById('cookieConsentBanner');
        const acceptBtn = document.getElementById('acceptCookies');
        
        // Check if user previously acknowledged the banner
        const consentStatus = localStorage.getItem('cookieConsent');
        
        if (consentStatus !== 'acknowledged') {
          // Show banner
          consentBanner.classList.add('show');
          
          acceptBtn.addEventListener('click', () => {
            localStorage.setItem('cookieConsent', 'acknowledged');
            consentBanner.classList.remove('show');
          });
        }
      })();
    </script>
    <script>
      // WebMCP Support for AI Agents
      if (typeof navigator !== 'undefined' && navigator.modelContext) {
        navigator.modelContext.provideContext({
          tools: [
            {
              name: "contact_developer",
              description: "Open the contact form to message the developer",
              inputSchema: {
                type: "object",
                properties: {}
              },
              execute: async (args) => {
                const navOverlay = document.getElementById("navOverlay");
                const modal = document.getElementById("contactModalOverlay");
                if (navOverlay) {
                  navOverlay.classList.remove("open");
                }
                if (modal) {
                  modal.classList.add("open");
                  return { success: true, message: "Contact form opened." };
                }
                return { success: false, message: "Failed to open contact form." };
              }
            }
          ]
        });
      }
    </script>
  </body>
</html>
