<div class="premium-banner">
  <h1>{{hero.name}}</h1>
  <p>{{#if hero.role_label}}{{hero.role_label}}{{else}}Software Engineer{{/if}} | {{hero.tagline}}</p>
  
  <div class="banner-socials" style="margin-top: 1.5rem; display: flex; gap: 1rem; justify-content: center;">
    {{#if site.github}}
    <a href="{{site.github}}" target="_blank" rel="noopener noreferrer" aria-label="GitHub" style="color: rgba(255,255,255,0.9); transition: color 0.2s ease, transform 0.2s ease;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
    </a>
    {{/if}}
    {{#if site.linkedin}}
    <a href="{{site.linkedin}}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" style="color: rgba(255,255,255,0.9); transition: color 0.2s ease, transform 0.2s ease;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
    </a>
    {{/if}}
  </div>
</div>

<div class="layout-container">
  <div class="layout-grid">
    <main class="main-column">
      <section id="home" class="premium-card hero-card">
        {{> hero}}
      </section>

      <section id="about" class="premium-card">
        <h2 class="premium-card-title">Professional Summary</h2>
        {{> about}}
      </section>

      {{> projects}}

      <section id="experience" class="premium-card">
        <h2 class="premium-card-title">Work Experience</h2>
        {{> experience}}
      </section>

      <section id="education" class="premium-card">
        <h2 class="premium-card-title">Education</h2>
        {{> education}}
      </section>

      <div id="journey-block">
        {{> know-more}}
      </div>
    </main>

    <aside class="sidebar-column">
      <section id="skills" class="premium-card">
        <h2 class="premium-card-title">Top Skills</h2>
        {{> skills}}
      </section>

      <section id="certificates" class="premium-card">
        <h2 class="premium-card-title">Certifications</h2>
        {{> certificates}}
      </section>
    </aside>
  </div>
</div>
