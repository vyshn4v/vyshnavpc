<div class="layout-container">
  <div class="layout-grid">
    
    <!-- Left Column: Main Content -->
    <div>
      <div class="premium-card">
        {{> hero}}
      </div>

      <div class="premium-card">
        <h2 class="premium-card-title">Profile Summary</h2>
        {{> about}}
      </div>

      <div class="premium-card">
        <h2 class="premium-card-title">Work Experience</h2>
        {{> experience}}
      </div>

      <div class="premium-card">
        <h2 class="premium-card-title">Education</h2>
        {{> education}}
      </div>
      
      <!-- Journey Teaser -->
      {{> know-more}}
    </div>

    <!-- Right Column: Sidebar -->
    <div>
      <div class="premium-card">
        <h2 class="premium-card-title">Top Skills</h2>
        {{> skills}}
      </div>

      <div class="premium-card">
        <h2 class="premium-card-title">Certifications</h2>
        {{> certificates}}
      </div>

      <div class="premium-card">
        <h2 class="premium-card-title">Contact</h2>
        {{> contact}}
      </div>
    </div>

  </div>

  <!-- Projects full-width span below the columns -->
  {{> projects}}

</div>

{{> footer}}
