<link rel="stylesheet" href="/css/mcq.css?v=1" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div class="mcq-container">
  <div class="mcq-header">
    <div class="header-left">
      <h1>Daily Practice</h1>
      <p>Sharpen your Full-Stack skills every day.</p>
    </div>
  </div>

  <div class="mcq-filters">
    <label for="topicFilter">Select Topic:</label>
    <select id="topicFilter">
      <option value="All">All Topics</option>
      <option value="JavaScript">JavaScript</option>
      <option value="React.js">React.js</option>
      <option value="Node.js">Node.js</option>
      <option value="TypeScript">TypeScript</option>
      <option value="Redux">Redux</option>
      <option value="Docker">Docker</option>
      <option value="Kubernetes">Kubernetes</option>
    </select>
    <button class="next-btn" onclick="markComplete()" style="margin-left: auto;">✅ Mark Complete</button>
  </div>

  <div class="quiz-area" id="quizArea">
    <div class="loading">Loading questions...</div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", async () => {
  const quizArea = document.getElementById('quizArea');
  const topicFilter = document.getElementById('topicFilter');
  const scoreDisplay = document.getElementById('scoreDisplay');
  
  let allQuestions = [];
  let currentQuestions = [];
  let currentQuestionIndex = 0;
  
  let score = 0;
  let attempts = 0;
  let attemptedLog = [];

  // Fetch JSON data from MongoDB API
  try {
    const res = await fetch('/practice/api/questions');
    if (!res.ok) throw new Error('Failed to load questions');
    allQuestions = await res.json();
    
    // Shuffle the array to randomize practice
    allQuestions.sort(() => 0.5 - Math.random());
    currentQuestions = [...allQuestions];
    renderQuestion();
  } catch (error) {
    quizArea.innerHTML = `<div class="error">Error loading questions. Please try again later.</div>`;
    console.error(error);
  }

  topicFilter.addEventListener('change', (e) => {
    const topic = e.target.value;
    if (topic === 'All') {
      currentQuestions = [...allQuestions];
    } else {
      currentQuestions = allQuestions.filter(q => q.topic === topic);
    }
    
    currentQuestions.sort(() => 0.5 - Math.random());
    currentQuestionIndex = 0;
    
    // Reset on topic change
    score = 0;
    attempts = 0;
    attemptedLog = [];
    renderQuestion();
  });



  window.selectOption = function(optionIndex) {
    const question = currentQuestions[currentQuestionIndex];
    const options = document.querySelectorAll('.mcq-option');
    const isCorrect = optionIndex === question.answerIndex;
    
    // Disable all options
    options.forEach(opt => {
        opt.style.pointerEvents = 'none';
        opt.disabled = true;
    });
    
    attempts++;
    if (isCorrect) score++;
    
    attemptedLog.push({
      topic: question.topic,
      questionText: question.question,
      isCorrect: isCorrect,
      explanation: question.explanation
    });

    const selectedOpt = options[optionIndex];
    if (isCorrect) {
      selectedOpt.classList.add('correct');
    } else {
      selectedOpt.classList.add('incorrect');
      options[question.answerIndex].classList.add('correct');
    }

    // Show Explanation
    const explanationDiv = document.createElement('div');
    explanationDiv.className = 'mcq-explanation fade-in';
    explanationDiv.innerHTML = `
      <strong>${isCorrect ? '✅ Correct!' : '❌ Incorrect!'}</strong>
      <p>${question.explanation}</p>
      <button class="next-btn" onclick="nextQuestion()">Next Question ➔</button>
    `;
    quizArea.appendChild(explanationDiv);
  };

  window.nextQuestion = function() {
    currentQuestionIndex++;
    renderQuestion();
  };

  function renderQuestion() {
    if (currentQuestions.length === 0) {
      quizArea.innerHTML = `<div class="no-questions">No questions available for this topic.</div>`;
      return;
    }

    if (currentQuestionIndex >= currentQuestions.length) {
      markComplete();
      return;
    }

    const question = currentQuestions[currentQuestionIndex];
    
    const html = `
      <div class="mcq-card fade-in">
        <div class="mcq-topic-badge">${question.topic}</div>
        <h2 class="mcq-question-text">Q${currentQuestionIndex + 1}. ${question.question.replace(/`([^`]+)`/g, '<code>$1</code>')}</h2>
        
        <div class="mcq-options-list">
          ${question.options.map((opt, i) => `
            <button class="mcq-option" onclick="selectOption(${i})">
              <span class="opt-letter">${String.fromCharCode(65 + i)}</span>
              <span class="opt-text">${opt.replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/`([^`]+)`/g, '<code>$1</code>')}</span>
            </button>
          `).join('')}
        </div>
      </div>
    `;
    
    quizArea.innerHTML = html;
  }

  window.markComplete = function() {
    const topicsPracticed = [...new Set(attemptedLog.map(log => log.topic))].join(', ') || 'None';
    
    quizArea.innerHTML = `
      <div class="quiz-complete fade-in">
        <h2>Practice Complete! 🎉</h2>
        <p>You answered <strong>${attempts}</strong> questions.</p>
        <p>Your Final Score: <strong>${score} / ${attempts}</strong></p>
        <br>
        <button class="next-btn" style="background: #28a745; margin-right: 15px;" onclick="downloadPDF()">📄 Download Report</button>
        <button class="next-btn" onclick="location.reload()">Start Over</button>
      </div>
    `;
  };

  window.downloadPDF = function() {
    const topicsPracticed = [...new Set(attemptedLog.map(log => log.topic))].join(', ') || 'None';
    
    // Create a temporary hidden div for the PDF content
    const reportDiv = document.createElement('div');
    reportDiv.style.padding = '40px';
    reportDiv.style.fontFamily = 'Arial, sans-serif';
    reportDiv.style.color = '#333';
    
    let htmlContent = `
      <h1 style="color: #ff3366; border-bottom: 2px solid #ff3366; padding-bottom: 10px;">Daily Practice Report</h1>
      <p><strong>Date:</strong> ${new Date().toLocaleDateString()}</p>
      <p><strong>Topics Covered:</strong> ${topicsPracticed}</p>
      <p><strong>Total Score:</strong> ${score} / ${attempts}</p>
      <br>
      <h2>Questions Summary</h2>
      <hr>
    `;

    if (attemptedLog.length === 0) {
      htmlContent += `<p>No questions answered in this session.</p>`;
    } else {
      attemptedLog.forEach((log, idx) => {
        const color = log.isCorrect ? 'green' : 'red';
        const icon = log.isCorrect ? '✅' : '❌';
        htmlContent += `
          <div style="margin-bottom: 20px; page-break-inside: avoid;">
            <p><strong>Q${idx + 1}. [${log.topic}]</strong> ${log.questionText}</p>
            <p style="color: ${color}; font-weight: bold;">Result: ${icon} ${log.isCorrect ? 'Correct' : 'Incorrect'}</p>
            <p style="font-size: 0.9em; color: #555;"><em>Explanation:</em> ${log.explanation}</p>
          </div>
        `;
      });
    }

    reportDiv.innerHTML = htmlContent;

    // Use html2pdf to generate and download
    const opt = {
      margin:       10,
      filename:     'practice-report.pdf',
      image:        { type: 'jpeg', quality: 0.98 },
      html2canvas:  { scale: 2 },
      jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
    };

    html2pdf().set(opt).from(reportDiv).save();
  };
});
</script>
