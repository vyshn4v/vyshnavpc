  // JavaScript
  { topic: "JavaScript", question: "What is the output of `typeof null` in JavaScript?", options: ["\"null\"", "\"undefined\"", "\"object\"", "\"boolean\""], answerIndex: 2, explanation: "In JavaScript, `typeof null` returns `\"object\"`. This is considered a historical bug in the language." },
  { topic: "JavaScript", question: "Which array method returns a new array with all elements that pass the test implemented by the provided function?", options: ["map()", "filter()", "reduce()", "forEach()"], answerIndex: 1, explanation: "`filter()` creates a new array with all elements that pass the test." },
  { topic: "JavaScript", question: "What will `console.log(0.1 + 0.2 === 0.3)` print?", options: ["true", "false", "undefined", "NaN"], answerIndex: 1, explanation: "Due to floating-point math precision in JavaScript (IEEE 754 standard), `0.1 + 0.2` equals `0.30000000000000004`." },
  { topic: "JavaScript", question: "Which statement is true about closures in JavaScript?", options: ["Closures only work with global variables", "A closure gives you access to an outer function's scope from an inner function", "Closures are only used for data hiding", "Closures cause memory leaks in modern browsers"], answerIndex: 1, explanation: "A closure is the combination of a function bundled together with references to its surrounding state (the lexical environment)." },
  { topic: "JavaScript", question: "What does the `this` keyword refer to inside an arrow function?", options: ["The global object", "The object that called the function", "The element that received the event", "The `this` value of the enclosing lexical context"], answerIndex: 3, explanation: "Arrow functions do not bind their own `this`, instead they inherit the one from the parent scope." },
  { topic: "JavaScript", question: "How do you check if a property exists on an object?", options: ["`obj.hasProperty('key')`", "`'key' in obj`", "`obj.contains('key')`", "`obj.key != undefined`"], answerIndex: 1, explanation: "The `in` operator returns true if the specified property is in the specified object or its prototype chain." },
  { topic: "JavaScript", question: "What does `Promise.all()` do?", options: ["Returns a single Promise that resolves when all passed promises resolve", "Returns the first promise that resolves", "Runs promises synchronously", "Catches all errors from multiple promises"], answerIndex: 0, explanation: "`Promise.all()` takes an iterable of promises and returns a single Promise that resolves to an array of the results." },
  { topic: "JavaScript", question: "Which method is used to remove the last element from an array?", options: ["shift()", "pop()", "push()", "unshift()"], answerIndex: 1, explanation: "`pop()` removes the last element from an array and returns that element." },
  { topic: "JavaScript", question: "What is Event Delegation?", options: ["Passing events from child to parent components in React", "Attaching a single event listener to a parent element to manage events for its children", "Delegating event handling to a Web Worker", "A pattern to handle Node.js event loops"], answerIndex: 1, explanation: "Event delegation is a technique involving adding event listeners to a parent element instead of adding them to the descendant elements." },
  { topic: "JavaScript", question: "What is the purpose of the `bind()` method?", options: ["To permanently bind a `this` context to a function", "To merge two arrays", "To attach an event listener", "To immediately invoke a function"], answerIndex: 0, explanation: "The `bind()` method creates a new function that, when called, has its `this` keyword set to the provided value." },

  // React.js
  { topic: "React.js", question: "Which hook should be used to run a function only once when the component mounts?", options: ["useEffect(() => {}, [])", "useEffect(() => {})", "useMount(() => {})", "useMemo(() => {})"], answerIndex: 0, explanation: "Passing an empty dependency array `[]` to `useEffect` tells React that your effect doesn't depend on any values, so it runs once." },
  { topic: "React.js", question: "What does React use to increase performance by keeping a lightweight representation of the real DOM?", options: ["Shadow DOM", "Virtual DOM", "React DOM", "Fiber DOM"], answerIndex: 1, explanation: "React uses a Virtual DOM to optimize rendering by comparing snapshots and only updating changed parts." },
  { topic: "React.js", question: "How can you prevent a component from re-rendering if its props have not changed?", options: ["React.memo", "useReducer", "useRef", "React.preventUpdate"], answerIndex: 0, explanation: "`React.memo` is a higher-order component that memoizes the rendered output." },
  { topic: "React.js", question: "What is the primary difference between `useState` and `useReducer`?", options: ["`useReducer` is only for global state", "`useReducer` is for complex state logic involving multiple sub-values", "`useState` is faster", "`useReducer` works only with Redux"], answerIndex: 1, explanation: "`useReducer` is preferable when you have complex state logic that involves multiple sub-values or when the next state depends on the previous one." },
  { topic: "React.js", question: "What does the `key` prop do when rendering lists in React?", options: ["It provides a unique ID for styling", "It helps React identify which items have changed, are added, or are removed", "It encrypts the list data", "It is required for state management"], answerIndex: 1, explanation: "Keys help React identify changes in lists, improving rendering performance by only updating the modified elements." },
  { topic: "React.js", question: "What is Prop Drilling?", options: ["A performance optimization technique", "Passing props through multiple layers of components to reach a nested component", "Using props to drill into the DOM", "A testing method for React components"], answerIndex: 1, explanation: "Prop drilling is the process of passing data from one part of the React Component tree to another by going through other parts that do not need the data." },
  { topic: "React.js", question: "Which API is built into React to solve Prop Drilling without Redux?", options: ["React Router", "Context API", "React Server Components", "Hooks API"], answerIndex: 1, explanation: "The Context API provides a way to pass data through the component tree without having to pass props down manually at every level." },
  { topic: "React.js", question: "What does `useMemo` do?", options: ["Memoizes a callback function", "Memoizes the result of an expensive calculation", "Stores a reference to a DOM element", "Replaces Redux"], answerIndex: 1, explanation: "`useMemo` returns a memoized value, preventing expensive calculations from running on every render." },
  { topic: "React.js", question: "What is the difference between a Controlled and Uncontrolled component?", options: ["Controlled components have their state managed by React, uncontrolled by the DOM", "Controlled components are used in Redux, uncontrolled are not", "There is no difference", "Uncontrolled components are deprecated"], answerIndex: 0, explanation: "In a controlled component, form data is handled by a React component. The alternative is uncontrolled components, where form data is handled by the DOM itself." },
  { topic: "React.js", question: "What are React Server Components (RSC)?", options: ["Components that only run on the client", "Components that render exclusively on the server, reducing client bundle size", "A new name for Next.js", "A database ORM for React"], answerIndex: 1, explanation: "React Server Components allow developers to build apps that span the server and client, moving data fetching to the server and reducing bundle sizes." },

  // Node.js
  { topic: "Node.js", question: "Which core module in Node.js is used to handle file operations?", options: ["path", "os", "fs", "http"], answerIndex: 2, explanation: "The `fs` (File System) module provides an API for interacting with the file system." },
  { topic: "Node.js", question: "In Node.js, the Event Loop starts which phase first?", options: ["Poll", "Timers", "Check", "Close callbacks"], answerIndex: 1, explanation: "The Event Loop starts with the Timers phase, executing callbacks scheduled by `setTimeout()` and `setInterval()`." },
  { topic: "Node.js", question: "How can you utilize all CPU cores in a Node.js application?", options: ["Using the `cluster` module", "By setting `process.env.THREADS = 'max'`", "Node.js automatically does this", "Using the `worker_threads` module only"], answerIndex: 0, explanation: "The `cluster` module allows easy creation of child processes (workers) that share server ports, effectively utilizing multiple CPU cores." },
  { topic: "Node.js", question: "What is `process.nextTick()` used for?", options: ["To pause the event loop", "To schedule a callback function to be invoked in the next iteration of the Event Loop", "To schedule a callback function to be invoked immediately after the current operation completes", "To measure performance"], answerIndex: 2, explanation: "`process.nextTick()` adds a callback to the 'next tick queue', which is evaluated before the event loop continues to the next phase." },
  { topic: "Node.js", question: "Which statement is true about Node.js streams?", options: ["They read the entire file into memory before processing", "They process data piece by piece without keeping it all in memory", "They are only used for video playing", "They are slower than `fs.readFile`"], answerIndex: 1, explanation: "Streams are a way to handle reading/writing files, network communications, or any kind of end-to-end information exchange in an efficient way by processing data in chunks." },
  { topic: "Node.js", question: "What does the `path` module do?", options: ["Handles HTTP routing", "Provides utilities for working with file and directory paths", "Calculates the shortest path in a graph", "Connects to MongoDB"], answerIndex: 1, explanation: "The `path` module provides utilities for working with file and directory paths across different operating systems." },
  { topic: "Node.js", question: "What is the purpose of `package.json`?", options: ["To write JavaScript code", "To hold metadata relevant to the project and manage dependencies", "To configure the Nginx server", "To store user credentials"], answerIndex: 1, explanation: "`package.json` contains metadata about the project, lists dependencies, and defines npm scripts." },
  { topic: "Node.js", question: "How does Node.js handle asynchronous operations?", options: ["Using multi-threading", "Using the V8 Engine only", "Using non-blocking I/O and the Event Loop", "By pausing execution until the operation completes"], answerIndex: 2, explanation: "Node.js uses an event-driven, non-blocking I/O model that makes it lightweight and efficient." },
  { topic: "Node.js", question: "What is middleware in Express.js?", options: ["Software that connects to the database", "Functions that have access to the request and response objects, and the next function in the cycle", "A hardware component", "The React frontend"], answerIndex: 1, explanation: "Middleware functions can execute any code, make changes to the request/response objects, end the response cycle, or call the next middleware." },
  { topic: "Node.js", question: "What is the primary difference between `require()` and `import`?", options: ["`require` is ES6, `import` is CommonJS", "`require` is CommonJS, `import` is ES6 Modules", "They are exactly the same", "`require` is asynchronous, `import` is synchronous"], answerIndex: 1, explanation: "`require()` is part of the older CommonJS module system used traditionally in Node, while `import` is part of the modern ES6 Module standard." },

  // MongoDB & Databases
  { topic: "MongoDB", question: "What is a 'document' in MongoDB?", options: ["A table row", "A JSON-like BSON object", "A PDF file", "A relational join"], answerIndex: 1, explanation: "MongoDB stores data records as BSON documents, which are binary representations of JSON-like objects." },
  { topic: "MongoDB", question: "What is the purpose of an Index in MongoDB?", options: ["To compress data", "To enforce unique schemas", "To improve the speed of search operations", "To encrypt the database"], answerIndex: 2, explanation: "Indexes support the efficient execution of queries in MongoDB. Without indexes, MongoDB must perform a collection scan." },
  { topic: "MongoDB", question: "In Mongoose, what is a Schema?", options: ["The database name", "A mapping that defines the structure of the document, default values, and validators", "A connection string", "A raw SQL query"], answerIndex: 1, explanation: "A Mongoose schema defines the structure of the document, default values, validators, etc." },
  { topic: "MongoDB", question: "What does the Aggregation Pipeline do?", options: ["Connects multiple MongoDB clusters", "Processes data records and returns computed results using multiple stages", "Aggregates CSS files", "Automates database backups"], answerIndex: 1, explanation: "The aggregation pipeline is a framework for data aggregation modeled on the concept of data processing pipelines with multiple stages (e.g. $match, $group)." },
  { topic: "MongoDB", question: "What is the difference between referencing and embedding?", options: ["Embedding stores related data in a single document, referencing stores a link to another document", "Referencing is for NoSQL, embedding is for SQL", "There is no difference", "Embedding is deprecated"], answerIndex: 0, explanation: "Embedding keeps related data together in one document (faster reads), while referencing links documents together (better for large, unbounded data)." },
  { topic: "Redis", question: "What is Redis primarily used for?", options: ["As a primary relational database", "As an in-memory data structure store used as a database, cache, and message broker", "For long-term cold storage", "For rendering React apps"], answerIndex: 1, explanation: "Redis is an open source, in-memory data structure store, used as a database, cache, message broker, and streaming engine." },
  { topic: "Redis", question: "What happens when a Redis key reaches its TTL (Time To Live)?", options: ["The value is archived to disk", "The key is automatically deleted", "The application crashes", "The TTL resets"], answerIndex: 1, explanation: "When a key's TTL expires, Redis automatically deletes the key." },
  { topic: "PostgreSQL", question: "Which feature makes PostgreSQL different from MySQL?", options: ["It uses SQL", "It supports JSONB, advanced indexing, and is an Object-Relational Database", "It is NoSQL", "It doesn't support joins"], answerIndex: 1, explanation: "PostgreSQL is known for its advanced features like JSONB support, full-text search, and robust ACID compliance." },
  
  // Advanced Topics
  { topic: "System Design", question: "What does the CAP theorem state?", options: ["A distributed system can only provide two of: Consistency, Availability, Partition tolerance", "CPU, API, Performance", "Consistency, Accuracy, Precision", "A system must be centralized to work"], answerIndex: 0, explanation: "CAP theorem states that any distributed data store can only provide two of the following three guarantees: Consistency, Availability, and Partition tolerance." },
  { topic: "RabbitMQ", question: "What is an Exchange in RabbitMQ?", options: ["A place to trade cryptocurrencies", "The routing mechanism that decides which queues a message should go to", "A database index", "A Web Socket connection"], answerIndex: 1, explanation: "Messages are not published directly to a queue. Instead, the producer sends messages to an exchange, which routes them to queues based on rules." },
  
  // TypeScript
  { topic: "TypeScript", question: "What is the primary benefit of TypeScript over JavaScript?", options: ["It runs faster in the browser", "It adds static typing to catch errors at compile-time", "It replaces Node.js", "It has built-in database support"], answerIndex: 1, explanation: "TypeScript's main feature is static typing, which allows you to define types for variables, function parameters, and return values, catching errors before runtime." },
  { topic: "TypeScript", question: "Which keyword is used to define a custom type in TypeScript?", options: ["interface", "type", "Both A and B", "def"], answerIndex: 2, explanation: "Both `interface` and `type` can be used to define custom types, though they have subtle differences in how they can be extended." },
  { topic: "TypeScript", question: "What does the `any` type do?", options: ["Enforces strict type checking", "Opts out of type checking for that value", "Only allows strings or numbers", "Throws an error at compile time"], answerIndex: 1, explanation: "The `any` type disables type checking for a variable, effectively treating it like plain JavaScript." },
  { topic: "TypeScript", question: "What is a Generic in TypeScript?", options: ["A function that takes no arguments", "A way to create reusable components that work with a variety of types rather than a single one", "A built-in Array method", "A type of loop"], answerIndex: 1, explanation: "Generics allow you to write reusable, type-safe code where the type is provided as a parameter (e.g., `Array<T>`)." },
  { topic: "TypeScript", question: "What is the `Omit` utility type?", options: ["It removes a property from an object at runtime", "It constructs a type by picking all properties from a type and then removing specified keys", "It omits files from the compilation", "It deletes a variable"], answerIndex: 1, explanation: "`Omit<Type, Keys>` creates a new type with all properties from `Type` except for those specified in `Keys`." },

  // Redux Toolkit
  { topic: "Redux", question: "What is the recommended toolset for writing Redux logic today?", options: ["Vanilla Redux", "Redux Toolkit (RTK)", "React Context", "MobX"], answerIndex: 1, explanation: "Redux Toolkit is the official, recommended way to write Redux logic. It simplifies store setup, reduces boilerplate, and includes Immer for immutable updates." },
  { topic: "Redux", question: "What function in Redux Toolkit automatically generates action creators and action types?", options: ["createStore", "createSlice", "createReducer", "createAction"], answerIndex: 1, explanation: "`createSlice` accepts a slice name, initial state, and an object of reducer functions, and automatically generates the corresponding action creators." },
  { topic: "Redux", question: "How does Redux Toolkit handle immutable state updates?", options: ["It requires you to manually copy objects using the spread operator", "It uses the Immer library under the hood, allowing you to write \"mutating\" logic", "It doesn't support immutability", "It uses deep cloning algorithms"], answerIndex: 1, explanation: "RTK uses Immer, which lets you write simpler mutating logic (e.g., `state.value = 1`) that is safely translated into immutable updates." },
  { topic: "Redux", question: "Which RTK feature is designed specifically for data fetching and caching?", options: ["createAsyncThunk", "RTK Query", "Redux Thunk", "Redux Saga"], answerIndex: 1, explanation: "RTK Query is an advanced data fetching and caching tool designed to simplify loading data in a web application, eliminating the need to hand-write data fetching logic." },

  // Docker
  { topic: "Docker", question: "What is a Dockerfile?", options: ["A backup of a database", "A text document that contains all the commands a user could call on the command line to assemble an image", "A virtual machine configuration", "A script to install Docker"], answerIndex: 1, explanation: "A Dockerfile is a text document that contains the instructions used to build a Docker image." },
  { topic: "Docker", question: "What is the difference between a Docker Image and a Docker Container?", options: ["They are the same thing", "An image is a running instance of a container", "An image is a read-only template, a container is a runnable instance of an image", "An image is for Windows, a container is for Linux"], answerIndex: 2, explanation: "An image is the blueprint (read-only), while a container is the actual running process based on that blueprint." },
  { topic: "Docker", question: "What does `docker-compose` do?", options: ["It compresses Docker images to save disk space", "It is a tool for defining and running multi-container Docker applications", "It composes music", "It pushes images to Docker Hub"], answerIndex: 1, explanation: "Docker Compose allows you to define a multi-container application in a single YAML file and start all services with a single command." },
  { topic: "Docker", question: "What is a Docker Volume?", options: ["The loudness of the container", "A mechanism for persisting data generated by and used by Docker containers", "A network bridge", "A type of base image"], answerIndex: 1, explanation: "Volumes are the preferred mechanism for persisting data generated by and used by Docker containers, independent of the container's lifecycle." },

  // Kubernetes
