<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>404 — Page Not Found</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0c0f;
    --surface: #111317;
    --border: #1e2128;
    --border-glow: #2a3040;
    --text: #c9cdd6;
    --muted: #4a5060;
    --dim: #2a2e38;
    --green: #3dd68c;
    --green-dim: #1a4a35;
    --amber: #e8a838;
    --red: #e05454;
    --blue: #5b8dee;
    --cursor: #3dd68c;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Space Grotesk', sans-serif;
  }

  html, body {
    height: 100%;
    width: 100%;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--mono);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    overflow: hidden;
    position: relative;
  }

  /* Scanline overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    pointer-events: none;
    z-index: 100;
  }

  /* Floating particles */
  .particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    color: var(--muted);
    font-family: var(--mono);
    font-size: 11px;
    opacity: 0;
    animation: drift linear infinite;
    white-space: nowrap;
    user-select: none;
  }

  @keyframes drift {
    0% { opacity: 0; transform: translateY(110vh) rotate(0deg); }
    10% { opacity: 0.4; }
    90% { opacity: 0.2; }
    100% { opacity: 0; transform: translateY(-10vh) rotate(10deg); }
  }

  /* Grid noise background */
  .grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.3;
    pointer-events: none;
    z-index: 0;
  }

  /* Vignette */
  .vignette {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 50%, rgba(0,0,0,0.8) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Main container */
  .container {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 720px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Terminal window */
  .terminal {
    background: var(--surface);
    border: 1px solid var(--border-glow);
    border-radius: 10px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(61,214,140,0.04),
      0 32px 80px rgba(0,0,0,0.6),
      0 0 60px rgba(61,214,140,0.03);
    animation: terminalAppear 0.6s cubic-bezier(0.16,1,0.3,1) forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  @keyframes terminalAppear {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Title bar */
  .titlebar {
    background: #0e1014;
    border-bottom: 1px solid var(--border);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #e05454; }
  .dot.amber { background: #e8a838; }
  .dot.green { background: #3dd68c; animation: dotPulse 2s ease-in-out infinite; }

  @keyframes dotPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .tab-title {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    margin-left: 6px;
    flex: 1;
    text-align: center;
    letter-spacing: 0.02em;
  }

  /* Terminal body */
  .term-body {
    padding: 24px 28px 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* 404 hero number */
  .error-code {
    font-family: var(--mono);
    font-size: clamp(72px, 14vw, 120px);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1px var(--green-dim);
    letter-spacing: -4px;
    line-height: 1;
    margin-bottom: 6px;
    position: relative;
    animation: codeAppear 0.8s 0.3s cubic-bezier(0.16,1,0.3,1) both;
    transform-origin: left center;
  }

  @keyframes codeAppear {
    from { opacity: 0; transform: scale(0.95) translateX(-10px); }
    to { opacity: 1; transform: scale(1) translateX(0); }
  }

  .error-code .stroke-accent {
    -webkit-text-stroke: 1px rgba(61,214,140,0.5);
    color: rgba(61,214,140,0.06);
  }

  /* Glitch effect on 404 */
  .error-code::before,
  .error-code::after {
    content: '404';
    position: absolute;
    top: 0;
    left: 0;
    -webkit-text-stroke: 1px transparent;
  }

  .error-code::before {
    color: rgba(91,141,238,0.15);
    animation: glitch1 4s infinite;
    clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%);
  }

  .error-code::after {
    color: rgba(224,84,84,0.15);
    animation: glitch2 4s infinite;
    clip-path: polygon(0 60%, 100% 60%, 100% 75%, 0 75%);
  }

  @keyframes glitch1 {
    0%, 92%, 100% { transform: translate(0); opacity: 0; }
    93% { transform: translate(-3px, 1px); opacity: 1; }
    94% { transform: translate(2px, -1px); opacity: 1; }
    95% { transform: translate(0); opacity: 0; }
  }

  @keyframes glitch2 {
    0%, 94%, 100% { transform: translate(0); opacity: 0; }
    95% { transform: translate(3px, -1px); opacity: 1; }
    96% { transform: translate(-2px, 1px); opacity: 1; }
    97% { transform: translate(0); opacity: 0; }
  }

  /* Lines of terminal output */
  .line {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    line-height: 1.6;
    opacity: 0;
    animation: lineIn 0.4s ease forwards;
  }

  .line.cmd { margin-bottom: 2px; }
  .line.out { margin-bottom: 1px; }
  .line.err { margin-bottom: 2px; }
  .line.blank { height: 10px; opacity: 1; }

  @keyframes lineIn {
    from { opacity: 0; transform: translateX(-4px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .prompt { color: var(--green); flex-shrink: 0; }
  .cmd-text { color: var(--text); }
  .cmd-path { color: var(--blue); }
  .cmd-arg { color: var(--amber); }

  .out-text { color: var(--muted); }
  .out-text.bright { color: var(--text); }

  .err-icon { color: var(--red); flex-shrink: 0; }
  .err-text { color: var(--red); }
  .warn-icon { color: var(--amber); flex-shrink: 0; }
  .warn-text { color: var(--amber); }
  .ok-icon { color: var(--green); flex-shrink: 0; }

  .indent { padding-left: 22px; }

  /* Message card */
  .message-card {
    margin-top: 20px;
    border: 1px solid var(--border-glow);
    border-left: 2px solid var(--amber);
    border-radius: 6px;
    padding: 14px 18px;
    background: rgba(232,168,56,0.04);
    opacity: 0;
    animation: cardIn 0.5s ease forwards;
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .card-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 6px;
    font-weight: 500;
  }

  .card-message {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
    font-weight: 300;
  }

  .card-message span {
    color: var(--text);
    font-weight: 400;
  }

  /* Cursor blink */
  .cursor {
    display: inline-block;
    width: 8px;
    height: 14px;
    background: var(--cursor);
    vertical-align: middle;
    margin-left: 4px;
    animation: blink 1s step-end infinite;
    border-radius: 1px;
    flex-shrink: 0;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Status bar */
  .statusbar {
    background: var(--green);
    padding: 4px 16px;
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 11px;
    color: #0a1a10;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .statusbar .seg {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .statusbar .sep {
    color: rgba(0,0,0,0.3);
  }

  /* Floating astronaut */
  .float-wrap {
    position: fixed;
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    pointer-events: none;
    animation: floatIn 1s 0.8s cubic-bezier(0.16,1,0.3,1) both;
    opacity: 0.15;
  }

  @keyframes floatIn {
    from { opacity: 0; transform: translateY(-40%) rotate(10deg); }
    to { opacity: 0.12; transform: translateY(-50%) rotate(0deg); }
  }

  .astronaut {
    animation: astronautFloat 5s ease-in-out infinite;
  }

  @keyframes astronautFloat {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-20px) rotate(2deg); }
  }

  /* Responsive */
  @media (max-width: 600px) {
    .container { padding: 1rem; }
    .term-body { padding: 16px 18px 20px; }
    .float-wrap { display: none; }
    .error-code { font-size: 72px; }
  }
</style>
</head>
<body>

<div class="grid-bg"></div>
<div class="vignette"></div>
<div class="particles" id="particles"></div>

<!-- Floating ghost astronaut -->
<div class="float-wrap">
  <svg class="astronaut" width="200" height="260" viewBox="0 0 200 260" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Body -->
    <ellipse cx="100" cy="150" rx="52" ry="62" fill="#c9cdd6" stroke="#4a5060" stroke-width="1.5"/>
    <!-- Helmet -->
    <ellipse cx="100" cy="88" rx="42" ry="44" fill="#d4d8e2" stroke="#4a5060" stroke-width="1.5"/>
    <!-- Visor -->
    <ellipse cx="100" cy="88" rx="28" ry="30" fill="#1a2535" opacity="0.9"/>
    <ellipse cx="100" cy="88" rx="28" ry="30" fill="url(#visorGrad)" opacity="0.4"/>
    <!-- Reflection in visor -->
    <ellipse cx="91" cy="78" rx="7" ry="9" fill="white" opacity="0.08"/>
    <!-- Arms -->
    <ellipse cx="46" cy="148" rx="16" ry="30" fill="#c0c4cc" stroke="#4a5060" stroke-width="1.5" transform="rotate(-15 46 148)"/>
    <ellipse cx="154" cy="148" rx="16" ry="30" fill="#c0c4cc" stroke="#4a5060" stroke-width="1.5" transform="rotate(15 154 148)"/>
    <!-- Gloves -->
    <ellipse cx="37" cy="172" rx="13" ry="11" fill="#888" stroke="#4a5060" stroke-width="1"/>
    <ellipse cx="163" cy="172" rx="13" ry="11" fill="#888" stroke="#4a5060" stroke-width="1"/>
    <!-- Legs -->
    <rect x="72" y="198" width="22" height="40" rx="10" fill="#bbbfc8" stroke="#4a5060" stroke-width="1.5"/>
    <rect x="106" y="198" width="22" height="40" rx="10" fill="#bbbfc8" stroke="#4a5060" stroke-width="1.5"/>
    <!-- Boots -->
    <ellipse cx="83" cy="236" rx="16" ry="9" fill="#777" stroke="#4a5060" stroke-width="1"/>
    <ellipse cx="117" cy="236" rx="16" ry="9" fill="#777" stroke="#4a5060" stroke-width="1"/>
    <!-- Chest detail -->
    <rect x="84" y="132" width="32" height="22" rx="4" fill="#b0b4bc" stroke="#4a5060" stroke-width="1"/>
    <circle cx="94" cy="143" r="3" fill="#3dd68c" opacity="0.8"/>
    <circle cx="104" cy="143" r="3" fill="#e8a838" opacity="0.7"/>
    <!-- Question mark floating near -->
    <text x="152" y="75" font-family="monospace" font-size="28" fill="#3dd68c" opacity="0.7">?</text>
    <defs>
      <linearGradient id="visorGrad" x1="80" y1="65" x2="120" y2="110">
        <stop offset="0%" stop-color="#5b8dee" stop-opacity="0.6"/>
        <stop offset="100%" stop-color="#0a0c0f" stop-opacity="0"/>
      </linearGradient>
    </defs>
  </svg>
</div>

<div class="container">
  <div class="terminal">
    <div class="titlebar">
      <div class="dots">
        <div class="dot red"></div>
        <div class="dot amber"></div>
        <div class="dot green"></div>
      </div>
      <div class="tab-title">shell — bash — 80×24</div>
    </div>

    <div class="term-body">
      <div class="error-code">404</div>

      <div style="display:flex; flex-direction:column; gap:2px;">

        <div class="line cmd" style="animation-delay:0.5s">
          <span class="prompt">❯</span>
          <span class="cmd-text">GET <span class="cmd-arg">"/this/page"</span> → resolving...</span>
        </div>

        <div class="line err" style="animation-delay:0.9s">
          <span class="err-icon">✗</span>
          <span class="err-text">ENOTFOUND — route does not exist on this server</span>
        </div>

        <div class="line blank"></div>

        <div class="line out" style="animation-delay:1.2s">
          <span class="out-text indent">→ checked <span class="cmd-path">routes/</span> … nothing matched</span>
        </div>
        <div class="line out" style="animation-delay:1.45s">
          <span class="out-text indent">→ checked <span class="cmd-path">static/</span> … asset not deployed</span>
        </div>
        <div class="line out" style="animation-delay:1.7s">
          <span class="out-text indent">→ checked <span class="cmd-path">cache/</span> … cold miss</span>
        </div>
        <div class="line out" style="animation-delay:1.95s">
          <span class="out-text indent">→ checked <span class="cmd-path">logs/</span> … <span class="bright">no record of this path ever existing</span></span>
        </div>

        <div class="line blank"></div>

        <div class="line out" style="animation-delay:2.3s">
          <span class="warn-icon">⚠</span>
          <span class="warn-text">Process exited with status 404</span>
        </div>

        <div class="line cmd" style="animation-delay:2.7s; margin-top:6px;">
          <span class="prompt">❯</span>
          <span class="cmd-text">whoami — debug</span>
        </div>

        <div class="line out" style="animation-delay:3.0s">
          <span class="ok-icon">✓</span>
          <span class="out-text">author: <span class="bright">vyshnavpc</span> &nbsp;·&nbsp; role: backend-engineer</span>
        </div>
        <div class="line out" style="animation-delay:3.2s">
          <span class="ok-icon">✓</span>
          <span class="out-text">verdict: <span class="bright">this page was never written</span></span>
        </div>

        <div class="line blank"></div>

        <div class="line" style="animation-delay:3.5s">
          <span class="prompt">❯</span>
          <div class="cursor"></div>
        </div>
      </div>

      <div class="message-card" style="animation-delay:3.8s">
        <div class="card-label">// dev note</div>
        <div class="card-message">
          Looks like you've wandered somewhere I haven't built yet. 
          <span>This URL doesn't resolve to anything</span> — not a broken link, 
          not a server issue. It simply doesn't exist. 
          <span>Check the URL and try again,</span> or head back to wherever you came from.
        </div>
      </div>
    </div>

    <div class="statusbar">
      <span class="seg">● NORMAL</span>
      <span class="sep">|</span>
      <span class="seg">HTTP 404</span>
      <span class="sep">|</span>
      <span class="seg">route: unresolved</span>
      <span class="sep">|</span>
      <span class="seg" style="margin-left:auto">utf-8</span>
    </div>
  </div>
</div>

<script>
const codes = ['null', 'undefined', '{}', '[]', 'NaN', '0x0', 'void 0', 'err', '??', '...', '~', 'exit', '$PATH', '404', 'EOF', '/dev/null'];
const p = document.getElementById('particles');

function spawn() {
  const el = document.createElement('div');
  el.className = 'particle';
  el.textContent = codes[Math.floor(Math.random() * codes.length)];
  el.style.left = Math.random() * 100 + 'vw';
  el.style.animationDuration = (14 + Math.random() * 18) + 's';
  el.style.animationDelay = (Math.random() * 4) + 's';
  el.style.fontSize = (9 + Math.random() * 5) + 'px';
  el.style.opacity = '0';
  p.appendChild(el);
  setTimeout(() => el.remove(), 32000);
}

for (let i = 0; i < 18; i++) setTimeout(spawn, i * 600);
setInterval(spawn, 2200);
</script>

</body>
</html>