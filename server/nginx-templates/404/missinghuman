<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — Page Not Found</title>
    <link
        href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;600;700&display=swap"
        rel="stylesheet" />
    <style>
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        html,
        body {
            width: 100%;
            height: 100%
        }

        body {
            background: #08090c;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
        }

        .stars {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0
        }

        .star {
            position: absolute;
            background: #fff;
            border-radius: 50%;
            animation: twinkle var(--d) ease-in-out infinite alternate
        }

        @keyframes twinkle {
            from {
                opacity: 0.1
            }

            to {
                opacity: 0.8
            }
        }

        .page {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 700px;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 2rem 1rem 1.5rem
        }

        .scene {
            position: relative;
            width: 100%;
            max-width: 600px;
            height: 290px;
            overflow: hidden
        }

        .ground {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 60px;
            background: #0e1117;
            border-top: 1px solid #1c2535
        }

        .ground::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, #1f6feb33, transparent)
        }

        /* torch light */
        .torch-light {
            position: absolute;
            bottom: 115px;
            left: 168px;
            width: 360px;
            height: 220px;
            background: conic-gradient(from -16deg at 0% 60%, transparent 0deg, rgba(255, 175, 45, 0.06) 8deg, rgba(255, 190, 60, 0.12) 18deg, rgba(255, 200, 70, 0.06) 28deg, transparent 38deg);
            transform-origin: 0% 60%;
            animation: sweep 4s ease-in-out infinite;
            pointer-events: none;
            filter: blur(3px);
        }

        @keyframes sweep {

            0%,
            100% {
                transform: rotate(-12deg)
            }

            50% {
                transform: rotate(14deg)
            }
        }

        .ground-glow {
            position: absolute;
            bottom: 58px;
            left: 130px;
            width: 300px;
            height: 90px;
            background: radial-gradient(ellipse at 8% 80%, rgba(255, 155, 35, 0.16) 0%, transparent 60%);
            pointer-events: none;
            animation: glowsweep 4s ease-in-out infinite;
            transform-origin: 8% 80%;
        }

        @keyframes glowsweep {

            0%,
            100% {
                transform: rotate(-12deg);
                opacity: 0.8
            }

            50% {
                transform: rotate(14deg);
                opacity: 1
            }
        }

        /* question marks bg */
        .qmarks {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 60px;
            pointer-events: none
        }

        .qmark {
            position: absolute;
            font-family: 'JetBrains Mono', monospace;
            color: #1a2535;
            font-size: var(--fs);
            animation: qfloat var(--d) ease-in-out infinite alternate;
            user-select: none
        }

        @keyframes qfloat {
            from {
                transform: translateY(0) rotate(-5deg);
                opacity: 0.25
            }

            to {
                transform: translateY(-14px) rotate(5deg);
                opacity: 0.65
            }
        }

        /* ── HUMAN ── */
        .human {
            position: absolute;
            bottom: 58px;
            left: 88px;
            width: 80px;
            height: 190px;
            animation: bodysway 4s ease-in-out infinite;
            transform-origin: bottom center
        }

        @keyframes bodysway {

            0%,
            100% {
                transform: rotate(-1.2deg)
            }

            50% {
                transform: rotate(1.2deg)
            }
        }

        /* head */
        .head {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 40px;
            height: 44px;
            background: #e8b89a;
            border-radius: 50% 50% 46% 46%;
            border: 1.5px solid #c8926a
        }

        /* hair */
        .head::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            height: 22px;
            background: #2c1a0e;
            border-radius: 52% 52% 0 0
        }

        /* ear */
        .head::after {
            content: '';
            position: absolute;
            top: 15px;
            right: -6px;
            width: 8px;
            height: 11px;
            background: #e8b89a;
            border-radius: 50%;
            border-right: 1px solid #c8926a
        }

        .eye {
            position: absolute;
            top: 19px;
            left: 23px;
            width: 5px;
            height: 5px;
            background: #2c1a0e;
            border-radius: 50%
        }

        .eye::after {
            content: '';
            position: absolute;
            top: 1px;
            left: 1px;
            width: 2px;
            height: 2px;
            background: rgba(255, 255, 255, 0.6);
            border-radius: 50%
        }

        /* face expression — searching look */
        .eyebrow {
            position: absolute;
            top: 13px;
            left: 19px;
            width: 10px;
            height: 2px;
            background: #2c1a0e;
            border-radius: 2px;
            transform: rotate(-10deg)
        }

        .mouth {
            position: absolute;
            top: 30px;
            left: 14px;
            width: 12px;
            height: 4px;
            border-bottom: 2px solid #c8926a;
            border-radius: 0 0 4px 4px
        }

        /* neck */
        .neck {
            position: absolute;
            top: 42px;
            left: 50%;
            transform: translateX(-50%);
            width: 14px;
            height: 10px;
            background: #e8b89a
        }

        /* torso */
        .torso {
            position: absolute;
            top: 50px;
            left: 50%;
            transform: translateX(-50%);
            width: 44px;
            height: 58px;
            background: #1a3a5c;
            border-radius: 4px 4px 6px 6px;
            border: 1px solid #122840
        }

        .torso::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 14px;
            height: 8px;
            background: #e8b89a;
            border-radius: 0 0 6px 6px
        }

        .torso::after {
            content: '';
            position: absolute;
            top: 20px;
            left: 6px;
            width: 10px;
            height: 8px;
            border: 1px solid #122840;
            border-radius: 2px
        }

        /* right arm — extended forward holding torch, swaying */
        .arm-right {
            position: absolute;
            top: 52px;
            right: -2px;
            width: 14px;
            height: 50px;
            background: #1a3a5c;
            border-radius: 6px;
            transform-origin: top center;
            animation: armright 4s ease-in-out infinite;
            border: 1px solid #122840
        }

        @keyframes armright {

            0%,
            100% {
                transform: rotate(-62deg)
            }

            50% {
                transform: rotate(-52deg)
            }
        }

        .arm-right::after {
            content: '';
            position: absolute;
            bottom: -28px;
            right: 0;
            width: 14px;
            height: 30px;
            background: #e8b89a;
            border-radius: 4px;
            border: 1px solid #c8926a
        }

        /* left arm — casual sway at side */
        .arm-left {
            position: absolute;
            top: 52px;
            left: 0;
            width: 14px;
            height: 50px;
            background: #1a3a5c;
            border-radius: 6px;
            transform-origin: top center;
            animation: armleft 4s ease-in-out infinite;
            border: 1px solid #122840
        }

        @keyframes armleft {

            0%,
            100% {
                transform: rotate(18deg)
            }

            50% {
                transform: rotate(26deg)
            }
        }

        .arm-left::after {
            content: '';
            position: absolute;
            bottom: -26px;
            left: 0;
            width: 14px;
            height: 28px;
            background: #e8b89a;
            border-radius: 4px;
            border: 1px solid #c8926a
        }

        /* legs */
        .leg-left {
            position: absolute;
            top: 106px;
            left: 50%;
            transform: translateX(-88%);
            width: 18px;
            height: 52px;
            background: #1c2535;
            border-radius: 3px 3px 5px 5px;
            border: 1px solid #141c28;
            animation: legleft 4s ease-in-out infinite;
            transform-origin: top center
        }

        .leg-right {
            position: absolute;
            top: 106px;
            left: 50%;
            transform: translateX(10%);
            width: 18px;
            height: 52px;
            background: #1c2535;
            border-radius: 3px 3px 5px 5px;
            border: 1px solid #141c28;
            animation: legright 4s ease-in-out infinite;
            transform-origin: top center
        }

        @keyframes legleft {

            0%,
            100% {
                transform: translateX(-88%) rotate(-2.5deg)
            }

            50% {
                transform: translateX(-88%) rotate(2.5deg)
            }
        }

        @keyframes legright {

            0%,
            100% {
                transform: translateX(10%) rotate(2.5deg)
            }

            50% {
                transform: translateX(10%) rotate(-2.5deg)
            }
        }

        .boot-left {
            position: absolute;
            top: 155px;
            left: 50%;
            transform: translateX(-105%);
            width: 24px;
            height: 12px;
            background: #1a1a1a;
            border-radius: 2px 7px 4px 2px
        }

        .boot-right {
            position: absolute;
            top: 155px;
            left: 50%;
            transform: translateX(3%);
            width: 24px;
            height: 12px;
            background: #1a1a1a;
            border-radius: 2px 7px 4px 2px
        }

        /* shadow */
        .shadow {
            position: absolute;
            bottom: 2px;
            left: 50%;
            transform: translateX(-50%);
            width: 44px;
            height: 8px;
            background: rgba(0, 0, 0, 0.5);
            border-radius: 50%;
            animation: shadowpulse 4s ease-in-out infinite
        }

        @keyframes shadowpulse {

            0%,
            100% {
                width: 40px;
                opacity: 0.4
            }

            50% {
                width: 48px;
                opacity: 0.6
            }
        }

        /* ── TORCH ── */
        .torch {
            position: absolute;
            bottom: 126px;
            left: 154px;
            width: 82px;
            height: 18px;
            transform-origin: 0% 50%;
            animation: torchsway 4s ease-in-out infinite;
            z-index: 5
        }

        @keyframes torchsway {

            0%,
            100% {
                transform: rotate(-12deg)
            }

            50% {
                transform: rotate(8deg)
            }
        }

        .torch-body {
            position: absolute;
            left: 0;
            top: 4px;
            width: 54px;
            height: 11px;
            background: #8b5e2a;
            border-radius: 3px;
            border: 1px solid #6b4820
        }

        .torch-body::before {
            content: '';
            position: absolute;
            top: 2px;
            left: 8px;
            width: 38px;
            height: 3px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 2px
        }

        .torch-body::after {
            content: '';
            position: absolute;
            top: 0;
            left: 10px;
            width: 1px;
            height: 11px;
            background: #6b4820;
            box-shadow: 5px 0 0 #6b4820, 10px 0 0 #6b4820, 15px 0 0 #6b4820
        }

        .torch-head {
            position: absolute;
            right: 0;
            top: 1px;
            width: 30px;
            height: 16px;
            background: #2a2a2a;
            border-radius: 2px 8px 8px 2px;
            border: 1px solid #444;
            overflow: hidden
        }

        .torch-head::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 11px;
            height: 11px;
            background: #ffe066;
            border-radius: 50%;
            animation: flicker 0.11s ease-in-out infinite alternate
        }

        @keyframes flicker {
            0% {
                opacity: 0.85;
                transform: translate(-50%, -50%) scale(0.94);
                background: #ffd700
            }

            100% {
                opacity: 1;
                transform: translate(-50%, -50%) scale(1.12);
                background: #fff8c0
            }
        }

        .torch-head::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 60% 50%, rgba(255, 220, 80, 0.55) 0%, transparent 75%);
            animation: flicker2 0.14s ease-in-out infinite alternate
        }

        @keyframes flicker2 {
            0% {
                opacity: 0.5
            }

            100% {
                opacity: 1
            }
        }

        /* ── MISSING PAGE SIGN ── */
        .sign {
            position: absolute;
            right: 55px;
            bottom: 58px
        }

        .sign-board {
            width: 115px;
            padding: 10px 12px;
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 6px;
            text-align: center
        }

        .slabel {
            display: block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 9px;
            color: #484f58;
            margin-bottom: 4px;
            letter-spacing: 1px
        }

        .scode {
            display: block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 26px;
            font-weight: 700;
            color: #f85149;
            animation: codepulse 2s ease-in-out infinite;
            letter-spacing: -1px
        }

        @keyframes codepulse {

            0%,
            100% {
                opacity: 1
            }

            50% {
                opacity: 0.45
            }
        }

        .smsg {
            display: block;
            font-family: 'JetBrains Mono', monospace;
            font-size: 9px;
            color: #30363d;
            margin-top: 5px;
            letter-spacing: 0.5px
        }

        .sign-post {
            width: 3px;
            height: 28px;
            background: #21262d;
            margin: 0 auto
        }

        /* ── FOG ── */
        .fog {
            position: absolute;
            bottom: 55px;
            left: 0;
            right: 0;
            height: 45px;
            background: linear-gradient(90deg, rgba(8, 9, 12, 0.9) 0%, rgba(8, 9, 12, 0.15) 22%, rgba(8, 9, 12, 0) 45%, rgba(8, 9, 12, 0) 58%, rgba(8, 9, 12, 0.25) 78%, rgba(8, 9, 12, 0.95) 100%);
            pointer-events: none;
            animation: fogdrift 9s ease-in-out infinite alternate
        }

        @keyframes fogdrift {
            from {
                transform: translateX(-12px)
            }

            to {
                transform: translateX(12px)
            }
        }

        /* ── TEXT ── */
        .num404 {
            font-family: 'JetBrains Mono', monospace;
            font-size: clamp(70px, 17vw, 108px);
            font-weight: 700;
            color: #111720;
            letter-spacing: -5px;
            line-height: 1;
            margin-top: -8px
        }

        .num404 span {
            color: #58a6ff
        }

        .subtitle {
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            color: #8b949e;
            margin-top: 6px;
            text-align: center;
            letter-spacing: 0.3px
        }

        .subtitle b {
            color: #e6edf3;
            font-weight: 400
        }

        /* ── TERMINAL ── */
        .terminal {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 10px;
            width: 100%;
            max-width: 520px;
            overflow: hidden;
            margin-top: 20px
        }

        .tbar {
            background: #21262d;
            padding: 9px 14px;
            display: flex;
            align-items: center;
            gap: 6px;
            border-bottom: 1px solid #30363d
        }

        .dot {
            width: 11px;
            height: 11px;
            border-radius: 50%
        }

        .tbody {
            padding: 14px 18px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 12.5px;
            line-height: 1.9;
            color: #8b949e
        }

        .pr {
            color: #58a6ff
        }

        .er {
            color: #f85149
        }

        .gr {
            color: #3fb950
        }

        .yw {
            color: #d29922
        }

        .wh {
            color: #e6edf3
        }

        @keyframes blink {

            0%,
            100% {
                opacity: 1
            }

            50% {
                opacity: 0
            }
        }

        .cur {
            animation: blink 1s step-end infinite;
            color: #e6edf3
        }
    </style>
</head>

<body>

    <div class="stars" id="stars"></div>

    <div class="page">
        <div class="scene">

            <div class="torch-light"></div>
            <div class="ground-glow"></div>
            <div class="qmarks" id="qmarks"></div>

            <div class="human">
                <div class="shadow"></div>
                <div class="head">
                    <div class="eyebrow"></div>
                    <div class="eye"></div>
                    <div class="mouth"></div>
                </div>
                <div class="neck"></div>
                <div class="torso"></div>
                <div class="arm-right"></div>
                <div class="arm-left"></div>
                <div class="leg-left"></div>
                <div class="leg-right"></div>
                <div class="boot-left"></div>
                <div class="boot-right"></div>
            </div>

            <div class="torch">
                <div class="torch-body"></div>
                <div class="torch-head"></div>
            </div>

            <div class="sign">
                <div class="sign-board">
                    <span class="slabel">STATUS CODE</span>
                    <span class="scode">404</span>
                    <span class="smsg">page not found</span>
                </div>
                <div class="sign-post"></div>
            </div>

            <div class="fog"></div>
            <div class="ground"></div>

        </div>

        <div class="num404">4<span>0</span>4</div>
        <p class="subtitle">looks like <b>you wandered into the dark</b> &mdash; this page doesn't exist</p>

        <div class="terminal">
            <div class="tbar">
                <div class="dot" style="background:#ff5f57"></div>
                <div class="dot" style="background:#ffbd2e"></div>
                <div class="dot" style="background:#28c840"></div>
                <span style="font-size:11px;color:#8b949e;margin-left:6px;font-family:'JetBrains Mono',monospace">nginx
                    &mdash; error.log</span>
            </div>
            <div class="tbody">
                <div><span class="pr">&#10095;</span> <span class="wh">GET /<span style="color:#8b949e">???</span>
                        HTTP/1.1</span></div>
                <div><span class="er">[404]</span> no route matched &mdash; you're lost in the dark</div>
                <div><span class="yw">[hint]</span> double-check the URL you typed</div>
                <div><span class="gr">[tip] </span> head back to where you came from</div>
                <div style="margin-top:4px"><span class="pr">&#10095;</span> <span class="cur">&#9611;</span></div>
            </div>
        </div>
    </div>

    <script>
        const starsEl = document.getElementById('stars');
        for (let i = 0; i < 130; i++) {
            const s = document.createElement('div');
            s.className = 'star';
            const size = Math.random() * 2 + 0.4;
            s.style.cssText = `width:${size}px;height:${size}px;top:${Math.random() * 100}%;left:${Math.random() * 100}%;--d:${(Math.random() * 3 + 1.5).toFixed(1)}s;animation-delay:${(Math.random() * 4).toFixed(1)}s`;
            starsEl.appendChild(s);
        }
        const qEl = document.getElementById('qmarks');
        [
            { l: '6%', t: '14%', fs: '30px', d: '2.2s', dl: '0s' },
            { l: '20%', t: '32%', fs: '18px', d: '3.1s', dl: '0.5s' },
            { l: '40%', t: '7%', fs: '24px', d: '2.7s', dl: '0.9s' },
            { l: '63%', t: '22%', fs: '14px', d: '3.5s', dl: '0.2s' },
            { l: '80%', t: '8%', fs: '28px', d: '2.4s', dl: '1.1s' },
            { l: '90%', t: '38%', fs: '16px', d: '3.0s', dl: '0.6s' },
            { l: '14%', t: '58%', fs: '12px', d: '2.8s', dl: '0.3s' },
            { l: '72%', t: '52%', fs: '20px', d: '3.3s', dl: '0.8s' },
        ].forEach(q => {
            const el = document.createElement('div');
            el.className = 'qmark';
            el.textContent = '?';
            el.style.cssText = `left:${q.l};top:${q.t};--fs:${q.fs};--d:${q.d};animation-delay:${q.dl}`;
            qEl.appendChild(el);
        });
    </script>
</body>

</html>