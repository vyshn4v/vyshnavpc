{{#section "styles"}}
  <link rel="stylesheet" href="/css/blogs.css" />
{{/section}}

{{#section "scripts"}}
  <script src="/js/blogs.js"></script>
{{/section}}
<div class="page">

    {{! ── Nav ── }}
    <nav class="nav">
        <a href="{{nav.homeUrl}}" class="nav-brand"><span class="dot"></span> {{siteName}}</a>
        <div class="nav-links">
            {{#each nav.links}}
            <a href="{{this.url}}"{{#if this.active}} class="active"{{/if}}>{{this.label}}</a>
            {{/each}}
            <a href="{{nav.ctaUrl}}" class="nav-cta">{{nav.ctaLabel}}</a>
        </div>
    </nav>

    {{! ── Hero ── }}
    <header class="hero">
        <div class="hero-glow"></div>
        <div class="hero-eyebrow">{{hero.eyebrow}}</div>
        <h1>{{hero.headingLine1}}<br><em>{{hero.headingLine2}}</em></h1>
        <p class="hero-sub">{{hero.subheading}}</p>
        {{!-- <div class="stats">
            <div class="stat">
                <span class="stat-num">{{totalPosts}}<span>+</span></span>
                <span class="stat-label">Articles published</span>
            </div>
            <div class="stat">
                <span class="stat-num">{{totalCategories}}</span>
                <span class="stat-label">Topic categories</span>
            </div>
            <div class="stat">
                <span class="stat-num">{{avgReadTime}}<span>m</span></span>
                <span class="stat-label">Avg. read time</span>
            </div>
        </div> --}}
    </header>

    {{! ── Controls ── }}
    <div class="controls">
        <div class="search-wrap">
            <span class="search-icon">⌕</span>
            <input class="search-input" type="text" id="searchInput" placeholder="{{searchPlaceholder}}">
        </div>
        <div class="filter-tags" id="filterTagsEl">
            <div class="filter-tag on" data-tag="all">All</div>
            {{#each allTags}}
            <div class="filter-tag" data-tag="{{this}}">{{this}}</div>
            {{/each}}
        </div>
        <select class="sort-select" id="sortSelect">
            {{#each sortOptions}}
            <option value="{{this.value}}">{{this.label}}</option>
            {{/each}}
        </select>
    </div>

    {{! ── Blog section ── }}
    <main class="blog-section">

        {{! Featured post — rendered server-side }}
        {{#with featuredPost}}
        <div id="featuredWrap">
            <div class="section-heading reveal">
                <h2>Featured</h2>
                <span class="count-badge">Pinned post</span>
            </div>
            <a href="/blogs/{{href}}" class="featured reveal"
               data-tags="{{joinedTags}}"
               data-title="{{lowerCase title}}"
               data-excerpt="{{lowerCase excerpt}}">
                <div class="featured-img" style="background:linear-gradient(135deg,{{art.bgFrom}},{{art.bgTo}})">
                    {{{renderArt art}}}
                    <div class="featured-badge">&#x2B50; Featured</div>
                </div>
                <div class="featured-body">
                    <div>
                        <div class="featured-cat">{{joinedTags}}</div>
                        <div class="featured-title">{{title}}</div>
                        <p class="featured-excerpt">{{excerpt}}</p>
                    </div>
                    <div class="featured-footer">
                        <div class="post-meta">
                            <span>{{fmtDate date}}</span>
                            <span class="sep"></span>
                            <span>{{readTime}} min read</span>
                            <span class="sep"></span>
                            <span>{{level}}</span>
                        </div>
                        <span class="read-link">Read article &#8594;</span>
                    </div>
                </div>
            </a>
        </div>
        {{/with}}

        {{! All articles — rendered server-side }}
        <div class="section-heading reveal" style="margin-top:56px">
            <h2>All Articles</h2>
            <span class="count-badge" id="postCount">{{nonFeaturedCount}} posts</span>
        </div>

        <div class="cards-grid" id="cardsGrid">
            {{#each posts}}{{#unless this.featured}}
            <a class="card reveal"
               href="{{this.href}}"
               data-tags="{{this.joinedTags}}"
               data-title="{{lowerCase this.title}}"
               data-excerpt="{{lowerCase this.excerpt}}"
               data-date="{{this.date}}"
               data-read="{{this.readTime}}">
                <div class="card-art" style="background:linear-gradient(135deg,{{this.art.bgFrom}},{{this.art.bgTo}})">
                    {{{renderArt this.art}}}
                </div>
                <div class="card-body">
                    <div class="card-tags">
                        {{#each this.tagStyles}}
                        <span class="ctag" style="background:{{this.bg}};color:{{this.text}};border-color:{{this.border}}">{{this.name}}</span>
                        {{/each}}
                    </div>
                    <div class="card-title">{{this.title}}</div>
                    <p class="card-excerpt">{{this.excerpt}}</p>
                    <div class="card-footer">
                        <span>&#9203; {{this.readTime}} min read</span>
                        <span class="arrow-icon">&#8599;</span>
                    </div>
                </div>
            </a>
            {{/unless}}{{/each}}
        </div>

        <div class="no-results" id="noResults">
            <span class="nr-icon">&#128269;</span>
            {{noResultsText}}
        </div>

    </main>

    {{! ── Footer ── }}
    <footer class="footer">
        <p>{{footer.copyright}}</p>
        <div class="footer-links">
            {{#each footer.links}}
            <a href="{{this.url}}">{{this.label}}</a>
            {{/each}}
        </div>
    </footer>

</div>