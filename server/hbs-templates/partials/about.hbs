<section class="section" id="about">
  <div class="container">

    <div class="section-head reveal">
      <div class="section-eyebrow">// 01 — about</div>
      <h2 class="section-title">Hello <em>There!</em></h2>
    </div>

    <div class="about-grid">

      <div class="about-text reveal">
        {{#each about.bio_paragraphs}}
          <p class="about-bio">{{this}}</p>
        {{/each}}
        <div class="about-details">
          {{#each about.details}}
            <div class="about-row">
              <span class="about-key">{{this.label}}</span>
              <span class="about-val">{{this.value}}</span>
            </div>
          {{/each}}
        </div>
      </div>

      <div class="about-right reveal">
        <div class="section-eyebrow mb-16">// achievements</div>
        {{#each about.achievements}}
          <div class="achievement-card">
            <span class="achievement-icon">{{this.icon}}</span>
            <div>
              <div class="achievement-title">{{this.title}}</div>
              <div class="achievement-desc">{{this.desc}}</div>
            </div>
          </div>
        {{/each}}
      </div>

    </div>
  </div>
</section>