<section class="section section--alt" id="contact">
  <div class="container">

    <div class="section-head reveal">
      <div class="section-eyebrow">Let's Talk</div>
      <h2 class="section-title">Hire <em>me!</em></h2>
    </div>

    <div class="contact-wrap reveal">
      <p class="contact-lead">{{contact.lead}}</p>
      <div class="contact-links">
        <a href="mailto:{{site.email}}" class="clink">
          <span class="clink-icon">✉️</span>
          <span>{{site.email}}</span>
        </a>
        <a
          href="{{site.whatsapp}}"
          target="_blank"
          rel="noopener"
          class="clink"
        >
          <span class="clink-icon">📱</span>
          <span>{{site.phone}}</span>
        </a>
        <a
          href="{{site.linkedin}}"
          target="_blank"
          rel="noopener"
          class="clink"
        >
          <span class="clink-icon">💼</span>
          <span>LinkedIn</span>
        </a>
        <a href="{{site.github}}" target="_blank" rel="noopener" class="clink">
          <span class="clink-icon">⌨️</span>
          <span>GitHub</span>
        </a>
      </div>
    </div>

  </div>
</section>