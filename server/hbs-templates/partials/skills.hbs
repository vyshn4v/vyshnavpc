<section class="section section--alt" id="skills">
  <div class="container">

    <div class="section-head reveal">
      <div class="section-eyebrow">Tech Stack</div>
      <h2 class="section-title">Things I <em>work with</em></h2>
    </div>

    <div class="skills-grid">
      {{#each skills}}
        <div class="skill-card reveal" style="--clr:{{this.color}}">
          <div class="skill-icon-wrap">
            {{{this.icon}}}
          </div>
          <div class="skill-info">
            <span class="skill-name">{{this.name}}</span>
            <span class="skill-desc">{{this.desc}}</span>
          </div>
        </div>
      {{/each}}
    </div>

  </div>
</section>