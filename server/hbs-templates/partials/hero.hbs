<section class="hero" id="home">
  <div class="hero-glow hero-glow--1"></div>
  <div class="hero-glow hero-glow--2"></div>
  <div class="hero-inner">

    <div class="hero-text">
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        {{hero.eyebrow}}
      </div>
      <h1 class="hero-h1">
        <span class="hero-greeting">{{hero.greeting}}</span><br />
        <em>{{hero.name}}</em>
      </h1>
      <p class="hero-role">{{hero.role}}</p>
      <p class="hero-sub">{{hero.sub}}</p>
      <div class="hero-actions">
        <a
          href="{{hero.cta_primary.href}}"
          class="btn btn--primary"
        >{{hero.cta_primary.label}}</a>
        <a
          href="{{hero.cta_secondary.href}}"
          class="btn btn--ghost"
        >{{hero.cta_secondary.label}}</a>
      </div>
      <div class="hero-socials">
        <a
          href="{{site.github}}"
          target="_blank"
          rel="noopener"
          aria-label="GitHub"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          ><path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.6-4.04-1.6-.54-1.38-1.33-1.74-1.33-1.74-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.48 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.83.57C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"
            /></svg>
        </a>
        <a
          href="{{site.linkedin}}"
          target="_blank"
          rel="noopener"
          aria-label="LinkedIn"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          ><path
              d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"
            /></svg>
        </a>
        <a
          href="{{site.whatsapp}}"
          target="_blank"
          rel="noopener"
          aria-label="WhatsApp"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          ><path
              d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.91-2.2-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.07-.79.37-.27.3-1.03 1.01-1.03 2.46s1.06 2.85 1.2 3.05c.15.2 2.08 3.18 5.04 4.46.7.3 1.25.48 1.68.62.7.22 1.34.19 1.84.12.56-.08 1.76-.72 2.01-1.41.25-.69.25-1.28.17-1.41-.07-.12-.27-.2-.57-.35zM12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37A9.86 9.86 0 0 1 2.18 12C2.18 6.57 6.6 2.15 12.06 2.15c2.64 0 5.12 1.03 6.98 2.9a9.8 9.8 0 0 1 2.89 6.96c0 5.44-4.42 9.86-9.88 9.86zm8.41-18.28A11.82 11.82 0 0 0 12.04 0C5.42 0 .07 5.35.07 11.97c0 2.1.55 4.16 1.6 5.97L0 24l6.22-1.63a11.9 11.9 0 0 0 5.81 1.48h.01c6.62 0 12-5.35 12-11.97 0-3.2-1.25-6.2-3.51-8.46z"
            /></svg>
        </a>
        <a href="mailto:{{site.email}}" aria-label="Email">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          ><path
              d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"
            /></svg>
        </a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="tb tb--red"></span>
          <span class="tb tb--yellow"></span>
          <span class="tb tb--green"></span>
          <span class="terminal-title">vyshnav.js</span>
        </div>
        <div class="terminal-body">
          <p><span class="tk-kw">const</span>
            <span class="tk-var">dev</span>
            <span class="tk-op">=</span>
            {</p>
          <p class="indent"><span class="tk-key">name</span>:
            <span class="tk-str">"{{site.name}}"</span>,</p>
          <p class="indent"><span class="tk-key">role</span>:
            <span class="tk-str">"{{hero.role}}"</span>,</p>
          <p class="indent"><span class="tk-key">location</span>:
            <span class="tk-str">"{{site.location}}"</span>,</p>
          <p class="indent"><span class="tk-key">exp</span>:
            <span class="tk-num">{{terminal.exp}}</span>,</p>
          <p class="indent"><span class="tk-key">stack</span>: [</p>
          {{#each terminal.stack}}
            <p class="indent2"><span class="tk-str">"{{this.a}}"</span>,
              <span class="tk-str">"{{this.b}}"</span></p>
          {{/each}}
          <p class="indent">],</p>
          <p class="indent"><span class="tk-key">available</span>:
            <span class="tk-bool">{{terminal.available}}</span></p>
          <p>};</p>
          <p class="mt"><span class="tk-kw">console</span>.<span
              class="tk-fn"
            >log</span>(<span class="tk-str">"{{terminal.message}}"</span>);</p>
          <p class="cursor-line"><span class="cursor">▋</span></p>
        </div>
      </div>
    </div>

  </div>
  <div class="hero-stats">
    {{#each stats}}
      <div class="hstat">
        <span class="hstat-num">{{this.num}}<span
            class="hstat-suf"
          >{{this.suffix}}</span></span>
        <span class="hstat-label">{{this.label}}</span>
      </div>
    {{/each}}
  </div>
</section>