<section class="hero" id="home">
  <div class="hero-glow hero-glow--1"></div>
  <div class="hero-glow hero-glow--2"></div>
  <div class="hero-inner">

    <div class="hero-text">
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        {{hero.eyebrow_icon}}
        {{hero.eyebrow}}
      </div>
      <p class="hero-role-label">{{hero.role_label}}</p>
      <h1 class="hero-h1"><em>{{hero.name}}</em><br />
        <span class="hero-tagline">{{hero.tagline}}</span>
      </h1>
      <p class="hero-sub">{{hero.sub}}</p>
      <div class="hero-actions">
        <a
          href="{{hero.cta_primary.href}}"
          class="btn btn--primary"
        >{{hero.cta_primary.label}}</a>
        <a
          href="{{hero.cta_secondary.href}}"
          class="btn btn--ghost"
        >{{hero.cta_secondary.label}}</a>
      </div>
      <div class="hero-inline-stats">
        {{#each hero_stats}}
          <div class="his">
            <span class="his-val">{{this.value}}</span>
            <span class="his-label">{{this.label}}</span>
          </div>
        {{/each}}
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="tb tb--red"></span>
          <span class="tb tb--yellow"></span>
          <span class="tb tb--green"></span>
          <span class="terminal-title">vyshnav — zsh — 120×36</span>
        </div>
        <div class="terminal-body">
          <p class="t-tab"><span class="tk-prompt">profile.json</span><span
              class="tk-x"
            >✕</span>
            <span class="tk-inactive">zsh</span><span class="tk-x">✕</span>
            <span class="tk-inactive">node</span><span class="tk-x">✕</span></p>
          <p class="mt"><span class="tk-prompt">❯</span>
            <span class="tk-str">~/cat profile.json</span></p>
          <p>{</p>
          <p class="indent"><span class="tk-key">"name"</span>:
            <span class="tk-str">"{{site.name}}"</span>,</p>
          <p class="indent"><span class="tk-key">"role"</span>:
            <span class="tk-str">"{{hero.role_label}}"</span>,</p>
          <p class="indent"><span class="tk-key">"exp"</span>:
            <span class="tk-str">"{{terminal.exp}}"</span>,</p>
          <p class="indent"><span class="tk-key">"focus"</span>: [<span
              class="tk-str"
            >"APIs"</span>,<span class="tk-str">"DevOps"</span>,<span
              class="tk-str"
            >"Cloud"</span>],</p>
          <p class="indent"><span class="tk-key">"loc"</span>:
            <span class="tk-str">"{{site.location}}"</span>,</p>
          <p class="indent"><span class="tk-key">"status"</span>:
            <span class="tk-str">"{{terminal.status}}"</span></p>
          <p>}</p>
          <p class="mt"><span class="tk-prompt">❯</span>
            <span class="cursor">▋</span></p>
        </div>
      </div>
    </div>

  </div>
</section>